{
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/home", "permanent": false }
  ],
  "rewrites": [
    { "source": "/home", "destination": "/src/home.html" },
    { "source": "/((?!src/).*)", "destination": "/src/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    }
  ]
}
